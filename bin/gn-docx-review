#!/usr/bin/env bash
# Convert genome note markdown to DOCX for review (figures and tables inline).
# Usage: gn-docx-review INPUT.md [OUTPUT.docx]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"
TEMPLATES="$REPO_ROOT/templates"
FILTERS="$REPO_ROOT/filters"

caller_cwd="$(pwd)"
input="${1:?Usage: gn-docx-review INPUT.md [OUTPUT.docx]}"
case "$input" in
  /*) input_abs="$input" ;;
  *) input_abs="$caller_cwd/$input" ;;
esac
input_dir="$(cd "$(dirname "$input_abs")" && pwd)"
input_file="$(basename "$input_abs")"

output="${2:-${input_abs%.md}_review.docx}"
case "$output" in
  /*) output_abs="$output" ;;
  *) output_abs="$caller_cwd/$output" ;;
esac

(
  cd "$input_dir"
  pandoc "$input_file" \
    --lua-filter "$FILTERS/inject_frontmatter.lua" \
    --filter pandoc-crossref \
    --citeproc \
    --csl="$TEMPLATES/tol_custom-author-date.csl" \
    --reference-doc "$TEMPLATES/custom-template.docx" \
    -o "$output_abs"
)
