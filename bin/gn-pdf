#!/usr/bin/env bash
# Convert genome note markdown to PDF via XeLaTeX (Eisvogel template).
# Usage: gn-pdf INPUT.md [OUTPUT.pdf]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"
TEMPLATES="$REPO_ROOT/templates"

caller_cwd="$(pwd)"
input="${1:?Usage: gn-pdf INPUT.md [OUTPUT.pdf]}"
case "$input" in
  /*) input_abs="$input" ;;
  *) input_abs="$caller_cwd/$input" ;;
esac
input_dir="$(cd "$(dirname "$input_abs")" && pwd)"
input_file="$(basename "$input_abs")"

output="${2:-${input_abs%.md}.pdf}"
case "$output" in
  /*) output_abs="$output" ;;
  *) output_abs="$caller_cwd/$output" ;;
esac

(
  cd "$input_dir"
  pandoc "$input_file" \
    --to pdf \
    --template "$TEMPLATES/tol-eisvogel.latex" \
    --filter pandoc-crossref \
    --csl="$TEMPLATES/tol_custom-author-date.csl" \
    --citeproc \
    -V linkcolor=blue \
    -V wellcomefontpath="$TEMPLATES/fonts/" \
    --pdf-engine xelatex \
    -o "$output_abs"
)
