#!/usr/bin/env bash
# Convert genome note markdown to JATS XML for Wellcome Open Research submission.
# Usage: gn-jats INPUT.md [OUTPUT.xml]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"
TEMPLATES="$REPO_ROOT/templates"
FILTERS="$REPO_ROOT/filters"

caller_cwd="$(pwd)"
input="${1:?Usage: gn-jats INPUT.md [OUTPUT.xml]}"
case "$input" in
  /*) input_abs="$input" ;;
  *) input_abs="$caller_cwd/$input" ;;
esac
input_dir="$(cd "$(dirname "$input_abs")" && pwd)"
input_file="$(basename "$input_abs")"

output="${2:-${input_abs%.md}.xml}"
case "$output" in
  /*) output_abs="$output" ;;
  *) output_abs="$caller_cwd/$output" ;;
esac

(
  cd "$input_dir"
  pandoc "$input_file" \
    --lua-filter "$FILTERS/normalize_pandoc_inputs.lua" \
    --filter pandoc-crossref \
    --filter "$FILTERS/fix-figtbl-xref.py" \
    --csl="$TEMPLATES/tol_custom-author-date.csl" \
    --citeproc \
    --to=jats+element_citations \
    --template "$TEMPLATES/tol_jats_publishing.xml" \
    | "$FILTERS/postprocess-jats.py"
) > "$output_abs"
